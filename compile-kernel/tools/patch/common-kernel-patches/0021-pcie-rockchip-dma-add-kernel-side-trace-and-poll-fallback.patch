+						0, 0, 0, 0, 0, need_ack);
 		queue_work(obj->dma_trx_wq, &obj->dma_trx_work);
+	}
 
+	rk_pcie_dma_poll_done_fallback(obj);
 	rk_pcie_dma_recover_timeout(obj);
 
 	scan_ack_addr = obj->mem_base + PCIE_DMA_ACK_BASE;
@@ -500,6 +645,8 @@ static enum hrtimer_restart rk_pcie_scan_timer(struct hrtimer *timer)
 
 		sav = readl(addr);
 		if (sav == PCIE_DMA_DATA_ACK_CHECK) {
+			rk_pcie_dma_record_scan(obj, PCIE_DMA_SCAN_TRACE_ACK,
+							i, 0, 0, sav, 0, need_ack);
