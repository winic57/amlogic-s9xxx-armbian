 		rk_pcie_dma_record_read_dump(obj, out.lra);
+		raw_after = out;
 		if (copy_to_user(uarg, &out, sizeof(out)))
-			return rk_pcie_dma_ioctl_done(obj, cmd, &msg, -EFAULT);
+			return rk_pcie_dma_ioctl_done(obj, cmd, &msg, &raw_before,
