 	}
 
 	switch (cmd) {
@@ -604,10 +759,13 @@ static long rk_pcie_misc_ioctl(struct file *filp, unsigned int cmd, unsigned lon
 		addr = obj->mem_start;
 		if (is_rc(obj))
 			addr += PCIE_DMA_WR_BUF_SIZE;
-		dma_sync_single_for_cpu(dev, addr, PCIE_DMA_RD_BUF_SIZE, DMA_FROM_DEVICE);
+		dma_sync_single_for_cpu(dev, addr, PCIE_DMA_RD_BUF_SIZE,
