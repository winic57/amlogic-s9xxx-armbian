 		suv = readl(addr);
 		if (suv == PCIE_DMA_DATA_FREE_ACK_CHECK) {
+			rk_pcie_dma_record_scan(obj, PCIE_DMA_SCAN_TRACE_FREE_ACK,
+							i, 0, 0, 0, suv, need_ack);
 			rk_pcie_clear_ack(addr);
 			set_bit(i, &obj->remote_write_available);
 		}
@@ -572,6 +721,8 @@ static long rk_pcie_misc_ioctl(struct file *filp, unsigned int cmd, unsigned lon
 	struct device *dev = obj->dev;
 	union pcie_dma_ioctl_param msg = { };
 	union pcie_dma_ioctl_param out = { };
+	union pcie_dma_ioctl_param raw_before = { };
+	union pcie_dma_ioctl_param raw_after = { };
 	phys_addr_t addr;
 	void __user *uarg = (void __user *)arg;
 	int ret;
@@ -581,7 +732,10 @@ static long rk_pcie_misc_ioctl(struct file *filp, unsigned int cmd, unsigned lon
 	obj->last_ioctl_ret = 0;
 
 	if (copy_from_user(&msg, uarg, sizeof(msg)) != 0)
-		return rk_pcie_dma_ioctl_done(obj, cmd, NULL, -EFAULT);
+		return rk_pcie_dma_ioctl_done(obj, cmd, NULL, NULL, NULL, -EFAULT);
+
+	raw_before = msg;
+	raw_after = msg;
 
 	if (READ_ONCE(obj->dma_disabled) && rk_pcie_dma_cmd_needs_hw(cmd)) {
 		ret = rk_pcie_dma_disabled_ret(obj, cmd, &msg);
@@ -590,7 +744,8 @@ static long rk_pcie_misc_ioctl(struct file *filp, unsigned int cmd, unsigned lon
 		dev_warn_ratelimited(dev,
 				     "pcie dma disabled: mode=%u ioctl=0x%x ret=%d\n",
 				     READ_ONCE(obj->dma_failfast_mode), cmd, ret);
-		return rk_pcie_dma_ioctl_done(obj, cmd, &msg, ret);
+		return rk_pcie_dma_ioctl_done(obj, cmd, &msg, &raw_before,
