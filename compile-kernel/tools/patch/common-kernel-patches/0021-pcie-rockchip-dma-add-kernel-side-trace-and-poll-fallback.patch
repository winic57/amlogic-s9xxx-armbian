From 0000000000000000000000000000000000000021 Mon Sep 17 00:00:00 2001
From: Henry AI <henry.ai@example.com>
Date: Tue, 7 Jul 2026 17:20:00 +0800
Subject: [PATCH] pcie-rockchip-dma: add kernel-side trace and poll fallback

Add low-overhead kernel-side trace rings for the RK3399Pro NPU PCIe DMA
path so that /dev/pcie-dev userspace transactions can be compared against
vendor 4.4 and the .129 golden PCIe flow without live MMIO reads from
DebugFS.

The trace extension records:
- raw 20-byte ioctl payloads before/after handling;
- scan timer DATA/ACK/FREE_ACK/queue events;
- UDMA start register snapshots before/after descriptor kick;
- IRQ/timeout/poll-fallback status snapshots.

Keep the default runtime-safe state as dma_disabled=1 unless DT explicitly
sets rockchip,pcie-dma-enabled.  Add an opt-in debugfs
`dma_poll_done_fallback` knob that polls the UDMA interrupt status bit and
calls the normal done/abort wake-up path when the hardware
completion bit is latched but no interrupt reaches the host.

Signed-off-by: Henry AI <henry.ai@example.com>
---
 drivers/pci/controller/pcie-rockchip-dma.c | 341 +++++++++++++++++++++++++----
 drivers/pci/controller/pcie-rockchip-dma.h | 117 +++++++++-
 2 files changed, 414 insertions(+), 44 deletions(-)

diff --git a/drivers/pci/controller/pcie-rockchip-dma.c b/drivers/pci/controller/pcie-rockchip-dma.c
index 77e15e3..2660120 100755
--- a/drivers/pci/controller/pcie-rockchip-dma.c
+++ b/drivers/pci/controller/pcie-rockchip-dma.c
@@ -72,18 +72,94 @@ static void rk_pcie_dma_snapshot_regs(struct dma_trx_obj *obj)
 	rk_pcie_dma_snapshot_irq_regs(rockchip, obj);
 }
 
+static void rk_pcie_dma_record_scan(struct dma_trx_obj *obj, u32 event, u32 idx,
+				    u32 sdv, u32 data_idx, u32 sav, u32 suv,
+				    bool need_ack)
+{
+	struct dma_scan_trace *tr;
+	u32 head;
+
+	if (!obj)
+		return;
+
+	obj->scan_trace_count++;
+	head = obj->scan_trace_head++ & (PCIE_DMA_SCAN_TRACE_LEN - 1);
+	tr = &obj->scan_trace[head];
+
+	tr->seq = obj->scan_trace_count;
+	tr->ts_ns = ktime_get_ns();
+	tr->event = event;
+	tr->idx = idx;
+	tr->sdv = sdv;
+	tr->data_idx = data_idx;
+	tr->sav = sav;
+	tr->suv = suv;
+	tr->lwa = (u32)obj->local_write_available;
+	tr->rwa = (u32)obj->remote_write_available;
+	tr->lra = (u32)obj->local_read_available;
+	tr->need_ack = need_ack;
+	tr->queued = !list_empty(&obj->tbl_list);
+	tr->dma_free = obj->dma_free;
+}
+
 static void rk_pcie_start_dma_3399(struct dma_trx_obj *obj)
 {
 	struct rockchip_pcie *rockchip = dev_get_drvdata(obj->dev);
 	struct dma_table *tbl = obj->cur;
 	int chn = tbl->chn;
+	u32 base = PCIE_APB_CORE_UDMA_BASE + 0x14 * chn;
+	struct dma_start_trace *tr;
+	u32 head;
+	u32 before_status, before_enable, before_ctrl;
+	u32 after_status, after_enable, after_ctrl;
+
+	before_status = rockchip_pcie_read(rockchip,
+					   PCIE_APB_CORE_UDMA_BASE +
+					   PCIE_UDMA_INT_REG);
+	before_enable = rockchip_pcie_read(rockchip,
+					   PCIE_APB_CORE_UDMA_BASE +
+					   PCIE_UDMA_INT_ENABLE_REG);
+	before_ctrl = rockchip_pcie_read(rockchip, base + 0x00);
 
 	rockchip_pcie_write(rockchip, lower_32_bits(tbl->desc_dma),
-			    PCIE_APB_CORE_UDMA_BASE + 0x14 * chn + 0x04);
+			    base + 0x04);
 	rockchip_pcie_write(rockchip, upper_32_bits(tbl->desc_dma),
-			    PCIE_APB_CORE_UDMA_BASE + 0x14 * chn + 0x08);
+			    base + 0x08);
 	rockchip_pcie_write(rockchip, BIT(0) | (tbl->dir << 1),
-			    PCIE_APB_CORE_UDMA_BASE + 0x14 * chn + 0x00);
+			    base + 0x00);
+
+	after_status = rockchip_pcie_read(rockchip,
+					  PCIE_APB_CORE_UDMA_BASE +
+					  PCIE_UDMA_INT_REG);
+	after_enable = rockchip_pcie_read(rockchip,
+					  PCIE_APB_CORE_UDMA_BASE +
+					  PCIE_UDMA_INT_ENABLE_REG);
+	after_ctrl = rockchip_pcie_read(rockchip, base + 0x00);
+
+	obj->last_dma_status = after_status;
+	obj->last_udma_enable = after_enable;
+	obj->last_udma_ctrl = after_ctrl;
+	obj->last_udma_desc_lo = lower_32_bits(tbl->desc_dma);
+	obj->last_udma_desc_hi = upper_32_bits(tbl->desc_dma);
+
+	obj->dma_start_count++;
+	head = obj->dma_start_trace_head++ & (PCIE_DMA_START_TRACE_LEN - 1);
+	tr = &obj->dma_start_trace[head];
+
+	tr->seq = obj->dma_start_count;
+	tr->ts_ns = ktime_get_ns();
+	tr->type = tbl->type;
+	tr->chn = chn;
+	tr->dir = tbl->dir;
+	tr->desc_lo = lower_32_bits(tbl->desc_dma);
+	tr->desc_hi = upper_32_bits(tbl->desc_dma);
+	tr->before_status = before_status;
+	tr->before_enable = before_enable;
+	tr->before_ctrl = before_ctrl;
+	tr->after_status = after_status;
+	tr->after_enable = after_enable;
+	tr->after_ctrl = after_ctrl;
+	tr->list_empty = list_empty(&obj->tbl_list);
 }
 
 static void rk_pcie_dma_failfast_reset(struct dma_trx_obj *obj);
@@ -374,7 +450,9 @@ static int rk_pcie_dma_disabled_ret(struct dma_trx_obj *obj, unsigned int cmd,
 }
 
 static void rk_pcie_dma_record_ioctl(struct dma_trx_obj *obj, unsigned int cmd,
-				     const union pcie_dma_ioctl_param *msg, int ret)
+				     const union pcie_dma_ioctl_param *msg,
+				     const void *raw_before,
+				     const void *raw_after, int ret)
 {
 	struct dma_ioctl_trace *tr;
 	u32 head;
@@ -400,6 +478,10 @@ static void rk_pcie_dma_record_ioctl(struct dma_trx_obj *obj, unsigned int cmd,
 		tr->type = msg->in.type;
 		tr->count = msg->count;
 	}
+	if (raw_before)
+		memcpy(tr->raw_before, raw_before, sizeof(tr->raw_before));
+	if (raw_after)
+		memcpy(tr->raw_after, raw_after, sizeof(tr->raw_after));
 	tr->lwa = (u32)obj->local_write_available;
 	tr->rwa = (u32)obj->remote_write_available;
 	tr->lra = (u32)obj->local_read_available;
@@ -407,20 +489,30 @@ static void rk_pcie_dma_record_ioctl(struct dma_trx_obj *obj, unsigned int cmd,
 }
 
 static long rk_pcie_dma_ioctl_done(struct dma_trx_obj *obj, unsigned int cmd,
-				   const union pcie_dma_ioctl_param *msg, int ret)
+				   const union pcie_dma_ioctl_param *msg,
+				   const void *raw_before,
+				   const void *raw_after, int ret)
 {
-	rk_pcie_dma_record_ioctl(obj, cmd, msg, ret);
+	rk_pcie_dma_record_ioctl(obj, cmd, msg, raw_before, raw_after, ret);
 	return ret;
 }
 
 static void rk_pcie_dma_recover_timeout(struct dma_trx_obj *obj)
 {
+	struct rockchip_pcie *rockchip;
+
 	if (obj->dma_free || !obj->dma_timeout_ms)
 		return;
 
 	if (ktime_ms_delta(ktime_get(), obj->dma_start_time) < obj->dma_timeout_ms)
 		return;
 
+	rockchip = dev_get_drvdata(obj->dev);
+	if (rockchip)
+		rk_pcie_dma_record_irq_trace(rockchip, obj,
+					     PCIE_DMA_IRQ_TRACE_TIMEOUT,
+					     obj->last_dma_status);
+
 	obj->dma_timeout_count++;
 	dev_warn_ratelimited(obj->dev,
 			     "pcie dma timeout: cur_type=%u loop=%d threshold=%d udma_status=0x%x udma_en=0x%x client=0x%x mask=0x%x core=0x%x core_mask=0x%x ctrl=0x%x desc=%08x:%08x list_empty=%d\n",
@@ -448,6 +540,53 @@ static void rk_pcie_dma_recover_timeout(struct dma_trx_obj *obj)
 		queue_work(obj->dma_trx_wq, &obj->dma_trx_work);
 }
 
+static bool rk_pcie_dma_poll_done_fallback(struct dma_trx_obj *obj)
+{
+	struct rockchip_pcie *rockchip;
+	u32 status;
+	bool handled = false;
+
+	if (!obj || obj->dma_free || !READ_ONCE(obj->dma_poll_done_fallback))
+		return false;
+
+	rockchip = dev_get_drvdata(obj->dev);
+	if (!rockchip)
+		return false;
+
+	status = rockchip_pcie_read(rockchip,
+				    PCIE_APB_CORE_UDMA_BASE +
+				    PCIE_UDMA_INT_REG);
+	if (!(status & (BIT(0) | BIT(16))))
+		return false;
+
+	if (status & BIT(16)) {
+		obj->dma_poll_abort_fallback_count++;
+		rk_pcie_dma_record_irq_trace(rockchip, obj,
+					     PCIE_DMA_IRQ_TRACE_POLL_ABORT,
+					     status);
+		handled = true;
+	}
+
+	if (status & BIT(0)) {
+		obj->dma_poll_done_fallback_count++;
+		rk_pcie_dma_record_irq_trace(rockchip, obj,
+					     PCIE_DMA_IRQ_TRACE_POLL_DONE,
+					     status);
+		handled = true;
+	}
+
+	rockchip_pcie_write(rockchip, status,
+			    PCIE_APB_CORE_UDMA_BASE + PCIE_UDMA_INT_REG);
+	obj->last_dma_status = status;
+
+	if (status & BIT(16))
+		rk_pcie_dma_irq_abort(obj);
+	if (status & BIT(0))
+		rk_pcie_dma_irq_done(obj);
+
+	return handled;
+}
