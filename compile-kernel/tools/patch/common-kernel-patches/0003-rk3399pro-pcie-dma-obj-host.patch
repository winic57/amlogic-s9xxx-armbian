+struct dma_trx_obj *rk_pcie_dma_obj_probe(struct device *dev)
+{
+	struct dma_trx_obj *obj;
+	u32 busno = 0;
+	struct device_node *mem;
+	struct resource reg;
+	int ret;
+
+	obj = devm_kzalloc(dev, sizeof(*obj), GFP_KERNEL);
+	if (!obj)
+		return ERR_PTR(-ENOMEM);
+
+	obj->dev = dev;
+
+	if (of_property_read_u32(dev->of_node, "busno", &busno) == 0)
+		obj->busno = busno;
+
+	mem = of_parse_phandle(dev->of_node, "memory-region", 0);
+	if (!mem)
+		return ERR_PTR(-ENODEV);
+
+	ret = of_address_to_resource(mem, 0, &reg);
+	of_node_put(mem);
+	if (ret < 0)
+		return ERR_PTR(ret);
+
+	obj->mem_start = reg.start;
+	obj->mem_size = resource_size(&reg);
+	if (obj->mem_size < PCIE_DMA_MIN_MEM_SIZE)
+		return ERR_PTR(-EINVAL);
+
+	obj->mem_base = rk_pcie_map_kernel(obj->mem_start, obj->mem_size);
+	if (!obj->mem_base)
+		return ERR_PTR(-ENOMEM);
+
+	ret = rk_pcie_dma_table_alloc(obj);
+	if (ret)
+		goto err_unmap;
+
+	obj->dma_trx_wq = create_singlethread_workqueue("rk-pcie-dma");
+	if (!obj->dma_trx_wq) {
+		ret = -ENOMEM;
+		goto err_tables;
+	}
+
+	INIT_WORK(&obj->dma_trx_work, rk_pcie_dma_trx_work);
+	INIT_LIST_HEAD(&obj->tbl_list);
+	spin_lock_init(&obj->tbl_list_lock);
+	init_waitqueue_head(&obj->event_queue);
+	init_completion(&obj->done);
+	mutex_init(&obj->count_mutex);
+	obj->dma_free = true;
+
+	hrtimer_setup(&obj->scan_timer, rk_pcie_scan_timer, CLOCK_MONOTONIC, HRTIMER_MODE_REL);
+	hrtimer_start(&obj->scan_timer, ms_to_ktime(500), HRTIMER_MODE_REL);
+
+	obj->miscdev.minor = MISC_DYNAMIC_MINOR;
+	obj->miscdev.name = "pcie-dev";
+	obj->miscdev.fops = &rk_pcie_misc_fops;
+	obj->miscdev.parent = dev;
+
+	ret = misc_register(&obj->miscdev);
+	if (ret)
+		goto err_wq;
+
+#ifdef CONFIG_DEBUG_FS
+	obj->pcie_root = debugfs_create_dir("pcie", NULL);
+	if (!obj->pcie_root) {
+		ret = -EINVAL;
+		goto err_misc;
+	}
+
+	debugfs_create_file("pcie_trx", 0644, obj->pcie_root, obj,
+			    &rk_pcie_debugfs_fops);
+#endif
+
+	dev_info(dev, "registered misc device pcie-dev\n");
+	return obj;
+
+err_misc:
+	misc_deregister(&obj->miscdev);
+err_wq:
+	hrtimer_cancel(&obj->scan_timer);
+	destroy_workqueue(obj->dma_trx_wq);
+err_tables:
+	rk_pcie_dma_table_free(obj, PCIE_DMA_TABLE_NUM);
+err_unmap:
+	rk_pcie_unmap_kernel(obj->mem_base);
+	return ERR_PTR(ret);
+}
+
+void rk_pcie_dma_obj_remove(struct dma_trx_obj *obj)
+{
+	if (!obj)
+		return;
+
+	misc_deregister(&obj->miscdev);
+	hrtimer_cancel(&obj->scan_timer);
+	if (obj->dma_trx_wq)
+		destroy_workqueue(obj->dma_trx_wq);
+#ifdef CONFIG_DEBUG_FS
+	debugfs_remove_recursive(obj->pcie_root);
+#endif
+	rk_pcie_dma_table_free(obj, PCIE_DMA_TABLE_NUM);
+	if (obj->mem_base)
+		rk_pcie_unmap_kernel(obj->mem_base);
+}
diff --git a/drivers/pci/controller/pcie-rockchip-dma.h b/drivers/pci/controller/pcie-rockchip-dma.h
new file mode 100644
index 0000000..31697c1
--- /dev/null
+++ b/drivers/pci/controller/pcie-rockchip-dma.h
@@ -0,0 +1,94 @@
+/* SPDX-License-Identifier: GPL-2.0 */
+/*
+ * Copyright (C) 2018 Rockchip Electronics Co., Ltd.
+ */
+
+#ifndef _PCIE_ROCKCHIP_DMA_H
+#define _PCIE_ROCKCHIP_DMA_H
+
+#include <linux/completion.h>
+#include <linux/dma-direction.h>
+#include <linux/dma-mapping.h>
+#include <linux/hrtimer.h>
+#include <linux/list.h>
+#include <linux/miscdevice.h>
+#include <linux/mutex.h>
+#include <linux/spinlock.h>
+#include <linux/types.h>
+#include <linux/wait.h>
+#include <linux/workqueue.h>
+
+#define PCIE_DMA_TABLE_NUM			24
+#define PCIE_DMA_DATA_SND_TABLE_OFFSET		0x0
+#define PCIE_DMA_DATA_RCV_ACK_TABLE_OFFSET	0x8
+#define PCIE_DMA_DATA_FREE_ACK_TABLE_OFFSET	0x10
+
+enum dma_dir {
+	DMA_FROM_BUS,
+	DMA_TO_BUS,
+};
+
+struct dma_table {
+	u32			*descs;
+	dma_addr_t		desc_dma;
+	int			chn;
+	u32			dir;
+	u32			type;
+	struct list_head	tbl_node;
+};
+
+struct dma_trx_obj {
+	struct device			*dev;
+	int				loop_count;
+	int				loop_count_threshold;
+	void				*mem_base;
+	phys_addr_t			mem_start;
+	size_t				mem_size;
+	bool				dma_free;
+	unsigned long			local_write_available;
+	unsigned long			local_read_available;
+	unsigned long			remote_write_available;
+	spinlock_t			tbl_list_lock;
+	struct list_head		tbl_list;
+	struct work_struct		dma_trx_work;
+	wait_queue_head_t		event_queue;
+	struct workqueue_struct		*dma_trx_wq;
+	struct dma_table		*table[PCIE_DMA_TABLE_NUM];
+	struct dma_table		*cur;
+	struct hrtimer			scan_timer;
+	int				busno;
+	struct completion		done;
+	int				ref_count;
+	struct mutex			count_mutex;
+	unsigned long			irq_num;
+#ifdef CONFIG_DEBUG_FS
+	struct dentry			*pcie_root;
+#endif
+	struct miscdevice		miscdev;
+};
+
+struct dma_trx_obj *rk_pcie_dma_obj_probe(struct device *dev);
+void rk_pcie_dma_obj_remove(struct dma_trx_obj *obj);
+void rk_pcie_dma_irq_done(struct dma_trx_obj *obj);
+
+static inline void rk_pcie_handle_dma_interrupt(struct rockchip_pcie *rockchip)
+{
+	u32 dma_status;
+	struct dma_trx_obj *obj = rockchip->dma_obj;
+
+	if (!obj)
+		return;
+
+	dma_status = rockchip_pcie_read(rockchip,
+			PCIE_APB_CORE_UDMA_BASE + PCIE_UDMA_INT_REG);
+
+	rockchip_pcie_write(rockchip, dma_status,
+			PCIE_APB_CORE_UDMA_BASE + PCIE_UDMA_INT_REG);
+
+	WARN_ONCE(!(dma_status & 0x3), "dma_status 0x%x\n", dma_status);
+
+	if (dma_status & BIT(0))
+		rk_pcie_dma_irq_done(obj);
+}
+
+#endif /* _PCIE_ROCKCHIP_DMA_H */
