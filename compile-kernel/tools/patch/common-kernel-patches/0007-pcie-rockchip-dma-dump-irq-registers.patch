From 25c5219be20a94027d9ed14175bc651cd4154716 Mon Sep 17 00:00:00 2001
From: LPA3399Pro Maintainers <noreply@example.com>
Date: Mon, 6 Jul 2026 13:40:26 +0800
Subject: [PATCH] pcie-rockchip-dma: dump udma interrupt registers

---
 drivers/pci/controller/pcie-rockchip-dma.c  | 39 +++++++++++-
 drivers/pci/controller/pcie-rockchip-dma.h  | 70 +++++++++++++++++++++
 drivers/pci/controller/pcie-rockchip-host.c |  5 +-
 3 files changed, 111 insertions(+), 3 deletions(-)

diff --git a/drivers/pci/controller/pcie-rockchip-dma.c b/drivers/pci/controller/pcie-rockchip-dma.c
index d23a95611..65c54d771 100644
--- a/drivers/pci/controller/pcie-rockchip-dma.c
+++ b/drivers/pci/controller/pcie-rockchip-dma.c
@@ -50,18 +50,34 @@ static inline bool is_rc(struct dma_trx_obj *obj)
 	return obj->busno == 0;
 }
 
+static void rk_pcie_dma_snapshot_regs(struct dma_trx_obj *obj)
+{
+	struct rockchip_pcie *rockchip;
+
+	if (!obj || !obj->dev)
+		return;
+
+	rockchip = dev_get_drvdata(obj->dev);
+	if (!rockchip)
+		return;
+
+	rk_pcie_dma_snapshot_irq_regs(rockchip, obj);
+}
+
 static void rk_pcie_start_dma_3399(struct dma_trx_obj *obj)
 {
 	struct rockchip_pcie *rockchip = dev_get_drvdata(obj->dev);
 	struct dma_table *tbl = obj->cur;
 	int chn = tbl->chn;
 
+	rk_pcie_dma_snapshot_regs(obj);
 	rockchip_pcie_write(rockchip, lower_32_bits(tbl->desc_dma),
 			    PCIE_APB_CORE_UDMA_BASE + 0x14 * chn + 0x04);
 	rockchip_pcie_write(rockchip, upper_32_bits(tbl->desc_dma),
 			    PCIE_APB_CORE_UDMA_BASE + 0x14 * chn + 0x08);
 	rockchip_pcie_write(rockchip, BIT(0) | (tbl->dir << 1),
 			    PCIE_APB_CORE_UDMA_BASE + 0x14 * chn + 0x00);
+	rk_pcie_dma_snapshot_regs(obj);
 }
 
 static void rk_pcie_prepare_dma(struct dma_trx_obj *obj,
@@ -185,11 +201,16 @@ static void rk_pcie_dma_recover_timeout(struct dma_trx_obj *obj)
 		return;
 
 	obj->dma_timeout_count++;
+	rk_pcie_dma_snapshot_regs(obj);
 	dev_warn_ratelimited(obj->dev,
-			     "pcie dma timeout: cur_type=%u loop=%d threshold=%d status=0x%x list_empty=%d\n",
+			     "pcie dma timeout: cur_type=%u loop=%d threshold=%d udma_status=0x%x udma_en=0x%x client=0x%x mask=0x%x core=0x%x core_mask=0x%x ctrl=0x%x desc=%08x:%08x list_empty=%d\n",
 			     obj->cur ? obj->cur->type : 0xffffffff,
 			     obj->loop_count, obj->loop_count_threshold,
-			     obj->last_dma_status, list_empty(&obj->tbl_list));
+			     obj->last_dma_status, obj->last_udma_enable,
+			     obj->last_client_status, obj->last_client_mask,
+			     obj->last_core_status, obj->last_core_mask,
+			     obj->last_udma_ctrl, obj->last_udma_desc_hi,
+			     obj->last_udma_desc_lo, list_empty(&obj->tbl_list));
 
 	/*
 	 * Vendor 4.4 relies on UDMA done IRQ to release the single DMA
@@ -560,9 +581,23 @@ static int rk_pcie_debugfs_trx_show(struct seq_file *s, void *v)
 	seq_printf(s, "list : (%s), dma chn : (%s)\n",
 		   list_empty_now ? "empty" : "not empty",
 		   dma_obj->dma_free ? "free" : "busy");
+	rk_pcie_dma_snapshot_regs(dma_obj);
 	seq_printf(s, "last_status = 0x%x, timeout_ms = %u, timeouts = %lu, aborts = %lu\n",
 		   dma_obj->last_dma_status, dma_obj->dma_timeout_ms,
 		   dma_obj->dma_timeout_count, dma_obj->dma_abort_count);
+	seq_printf(s, "irq_counts: udma = %lu, subsys = %lu, client = %lu\n",
+		   dma_obj->udma_irq_count, dma_obj->subsys_irq_count,
+		   dma_obj->client_irq_count);
+	seq_printf(s, "client_status = 0x%x, client_mask = 0x%x, core_status = 0x%x, core_mask = 0x%x\n",
+		   dma_obj->last_client_status, dma_obj->last_client_mask,
+		   dma_obj->last_core_status, dma_obj->last_core_mask);
+	seq_printf(s, "udma_enable = 0x%x, udma_ctrl = 0x%x, udma_desc = %08x:%08x\n",
+		   dma_obj->last_udma_enable, dma_obj->last_udma_ctrl,
+		   dma_obj->last_udma_desc_hi, dma_obj->last_udma_desc_lo);
+	seq_printf(s, "last_subsys_status = 0x%x, last_subsys_core = 0x%x, last_client_irq_status = 0x%x\n",
+		   dma_obj->last_subsys_status,
+		   dma_obj->last_subsys_core_status,
+		   dma_obj->last_client_irq_status);
 
 	return 0;
 }
diff --git a/drivers/pci/controller/pcie-rockchip-dma.h b/drivers/pci/controller/pcie-rockchip-dma.h
index 465daecd8..f241c46e6 100644
--- a/drivers/pci/controller/pcie-rockchip-dma.h
+++ b/drivers/pci/controller/pcie-rockchip-dma.h
@@ -59,9 +59,23 @@ struct dma_trx_obj {
 	struct hrtimer			scan_timer;
 	ktime_t			dma_start_time;
 	u32				last_dma_status;
+	u32				last_client_status;
+	u32				last_client_mask;
+	u32				last_core_status;
+	u32				last_core_mask;
+	u32				last_udma_enable;
+	u32				last_udma_ctrl;
+	u32				last_udma_desc_lo;
+	u32				last_udma_desc_hi;
+	u32				last_subsys_status;
+	u32				last_subsys_core_status;
+	u32				last_client_irq_status;
 	u32				dma_timeout_ms;
 	unsigned long			dma_timeout_count;
 	unsigned long			dma_abort_count;
+	unsigned long			udma_irq_count;
+	unsigned long			subsys_irq_count;
+	unsigned long			client_irq_count;
 	int				busno;
 	struct completion		done;
 	int				ref_count;
@@ -78,6 +92,59 @@ void rk_pcie_dma_obj_remove(struct dma_trx_obj *obj);
 void rk_pcie_dma_irq_done(struct dma_trx_obj *obj);
 void rk_pcie_dma_irq_abort(struct dma_trx_obj *obj);
 
+static inline void rk_pcie_dma_snapshot_irq_regs(struct rockchip_pcie *rockchip,
+						 struct dma_trx_obj *obj)
+{
+	if (!rockchip || !obj)
+		return;
+
+	obj->last_dma_status = rockchip_pcie_read(rockchip,
+			PCIE_APB_CORE_UDMA_BASE + PCIE_UDMA_INT_REG);
+	obj->last_client_status = rockchip_pcie_read(rockchip,
+			PCIE_CLIENT_INT_STATUS);
+	obj->last_client_mask = rockchip_pcie_read(rockchip,
+			PCIE_CLIENT_INT_MASK);
+	obj->last_core_status = rockchip_pcie_read(rockchip,
+			PCIE_CORE_INT_STATUS);
+	obj->last_core_mask = rockchip_pcie_read(rockchip,
+			PCIE_CORE_INT_MASK);
+	obj->last_udma_enable = rockchip_pcie_read(rockchip,
+			PCIE_APB_CORE_UDMA_BASE + PCIE_UDMA_INT_ENABLE_REG);
+	obj->last_udma_ctrl = rockchip_pcie_read(rockchip,
+			PCIE_APB_CORE_UDMA_BASE + 0x00);
+	obj->last_udma_desc_lo = rockchip_pcie_read(rockchip,
+			PCIE_APB_CORE_UDMA_BASE + 0x04);
+	obj->last_udma_desc_hi = rockchip_pcie_read(rockchip,
+			PCIE_APB_CORE_UDMA_BASE + 0x08);
+}
+
+static inline void rk_pcie_dma_record_subsys_irq(struct rockchip_pcie *rockchip,
+						 u32 status, u32 core_status)
+{
+	struct dma_trx_obj *obj = rockchip ? rockchip->dma_obj : NULL;
+
+	if (!obj)
+		return;
+
+	obj->subsys_irq_count++;
+	obj->last_subsys_status = status;
+	obj->last_subsys_core_status = core_status;
+	rk_pcie_dma_snapshot_irq_regs(rockchip, obj);
+}
+
+static inline void rk_pcie_dma_record_client_irq(struct rockchip_pcie *rockchip,
+						 u32 status)
+{
+	struct dma_trx_obj *obj = rockchip ? rockchip->dma_obj : NULL;
+
+	if (!obj)
+		return;
+
+	obj->client_irq_count++;
+	obj->last_client_irq_status = status;
+	rk_pcie_dma_snapshot_irq_regs(rockchip, obj);
+}
+
 static inline void rk_pcie_handle_dma_interrupt(struct rockchip_pcie *rockchip)
 {
 	u32 dma_status;
@@ -86,9 +153,12 @@ static inline void rk_pcie_handle_dma_interrupt(struct rockchip_pcie *rockchip)
 	if (!obj)
 		return;
 
+	obj->udma_irq_count++;
 	dma_status = rockchip_pcie_read(rockchip,
 			PCIE_APB_CORE_UDMA_BASE + PCIE_UDMA_INT_REG);
 
+	rk_pcie_dma_snapshot_irq_regs(rockchip, obj);
+
 	rockchip_pcie_write(rockchip, dma_status,
 			PCIE_APB_CORE_UDMA_BASE + PCIE_UDMA_INT_REG);
 
diff --git a/drivers/pci/controller/pcie-rockchip-host.c b/drivers/pci/controller/pcie-rockchip-host.c
index 6817496ee..7240a0735 100644
--- a/drivers/pci/controller/pcie-rockchip-host.c
+++ b/drivers/pci/controller/pcie-rockchip-host.c
@@ -448,12 +448,14 @@ static irqreturn_t rockchip_pcie_subsys_irq_handler(int irq, void *arg)
 	struct rockchip_pcie *rockchip = arg;
 	struct device *dev = rockchip->dev;
 	u32 reg;
-	u32 sub_reg;
+	u32 sub_reg = 0;
 
 	reg = rockchip_pcie_read(rockchip, PCIE_CLIENT_INT_STATUS);
+	rk_pcie_dma_record_subsys_irq(rockchip, reg, 0);
 	if (reg & PCIE_CLIENT_INT_LOCAL) {
 		dev_dbg(dev, "local interrupt received\n");
 		sub_reg = rockchip_pcie_read(rockchip, PCIE_CORE_INT_STATUS);
+		rk_pcie_dma_record_subsys_irq(rockchip, reg, sub_reg);
 		if (sub_reg & PCIE_CORE_INT_PRFPE)
 			dev_dbg(dev, "parity error detected while reading from the PNP receive FIFO RAM\n");
 
@@ -522,6 +524,7 @@ static irqreturn_t rockchip_pcie_client_irq_handler(int irq, void *arg)
 	u32 reg;
 
 	reg = rockchip_pcie_read(rockchip, PCIE_CLIENT_INT_STATUS);
+	rk_pcie_dma_record_client_irq(rockchip, reg);
 	if (reg & PCIE_CLIENT_INT_LEGACY_DONE)
 		dev_dbg(dev, "legacy done interrupt received\n");
 
-- 
2.43.0

