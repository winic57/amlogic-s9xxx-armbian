diff --git a/drivers/pci/controller/pcie-rockchip-host.c b/drivers/pci/controller/pcie-rockchip-host.c
index ee1822ca0..6b219f263 100644
--- a/drivers/pci/controller/pcie-rockchip-host.c
+++ b/drivers/pci/controller/pcie-rockchip-host.c
@@ -209,6 +209,7 @@ static int rockchip_pcie_rd_conf(struct pci_bus *bus, u32 devfn, int where,
 				 int size, u32 *val)
 {
 	struct rockchip_pcie *rockchip = bus->sysdata;
+	u32 status;
 
 	if (!rockchip_pcie_valid_device(rockchip, bus, PCI_SLOT(devfn)))
 		return PCIBIOS_DEVICE_NOT_FOUND;
@@ -216,6 +217,10 @@ static int rockchip_pcie_rd_conf(struct pci_bus *bus, u32 devfn, int where,
 	if (pci_is_root_bus(bus))
 		return rockchip_pcie_rd_own_conf(rockchip, where, size, val);
 
+	status = rockchip_pcie_read(rockchip, PCIE_CORE_CTRL_PLC1);
+	if (!PCIE_LINK_UP(status))
+		return PCIBIOS_DEVICE_NOT_FOUND;
+
 	return rockchip_pcie_rd_other_conf(rockchip, bus, devfn, where, size,
 					   val);
 }
@@ -224,6 +229,7 @@ static int rockchip_pcie_wr_conf(struct pci_bus *bus, u32 devfn,
 				 int where, int size, u32 val)
 {
 	struct rockchip_pcie *rockchip = bus->sysdata;
+	u32 status;
 
 	if (!rockchip_pcie_valid_device(rockchip, bus, PCI_SLOT(devfn)))
 		return PCIBIOS_DEVICE_NOT_FOUND;
@@ -231,6 +237,10 @@ static int rockchip_pcie_wr_conf(struct pci_bus *bus, u32 devfn,
 	if (pci_is_root_bus(bus))
 		return rockchip_pcie_wr_own_conf(rockchip, where, size, val);
 
+	status = rockchip_pcie_read(rockchip, PCIE_CORE_CTRL_PLC1);
+	if (!PCIE_LINK_UP(status))
+		return PCIBIOS_DEVICE_NOT_FOUND;
+
 	return rockchip_pcie_wr_other_conf(rockchip, bus, devfn, where, size,
 					   val);
 }
@@ -285,12 +295,21 @@ static int rockchip_pcie_host_init_port(struct rockchip_pcie *rockchip)
 	struct device *dev = rockchip->dev;
 	int err, i = MAX_LANE_NUM;
 	u32 status;
+	int attempt_counter = 0;
+	bool link_is_up = true;
 
+err_retry_init:
 	gpiod_set_value_cansleep(rockchip->perst_gpio, 0);
 
 	err = rockchip_pcie_init_port(rockchip);
-	if (err)
+	if (err) {
+		if (attempt_counter++ < 5) {
+			dev_warn(dev, "PCIe init port failed, retrying (%d/5)...\n", attempt_counter);
+			msleep(100);
+			goto err_retry_init;
+		}
 		return err;
+	}
 
 	/* Fix the transmitted FTS count desired to exit from L0s. */
 	status = rockchip_pcie_read(rockchip, PCIE_CORE_CTRL_PLC1);
@@ -325,7 +344,20 @@ static int rockchip_pcie_host_init_port(struct rockchip_pcie *rockchip)
 				 500 * USEC_PER_MSEC);
 	if (err) {
 		dev_err(dev, "PCIe link training gen1 timeout!\n");
-		goto err_power_off_phy;
+		if (attempt_counter++ < 5) {
+			dev_warn(dev, "Retrying PCIe link training (%d/5)...\n", attempt_counter);
+			i = MAX_LANE_NUM;
+			while (i--)
+				phy_power_off(rockchip->phys[i]);
+			i = MAX_LANE_NUM;
+			while (i--)
+				phy_exit(rockchip->phys[i]);
+			msleep(200);
+			goto err_retry_init;
+		}
+		dev_warn(dev, "Ignoring link training timeout to keep REFCLK running\n");
+		link_is_up = false;
+		err = 0;
 	}
 
 	if (rockchip->link_gen == 2) {
@@ -355,12 +387,17 @@ static int rockchip_pcie_host_init_port(struct rockchip_pcie *rockchip)
 	dev_dbg(dev, "current link width is x%d\n", status);
 
 	/* Power off unused lane(s) */
-	rockchip->lanes_map = rockchip_pcie_lane_map(rockchip);
-	for (i = 0; i < MAX_LANE_NUM; i++) {
-		if (!(rockchip->lanes_map & BIT(i))) {
-			dev_dbg(dev, "idling lane %d\n", i);
-			phy_power_off(rockchip->phys[i]);
+	if (link_is_up) {
+		rockchip->lanes_map = rockchip_pcie_lane_map(rockchip);
+		for (i = 0; i < MAX_LANE_NUM; i++) {
+			if (!(rockchip->lanes_map & BIT(i))) {
+				dev_dbg(dev, "idling lane %d\n", i);
+				phy_power_off(rockchip->phys[i]);
+			}
 		}
+	} else {
+		dev_info(dev, "Link is down, keeping all lanes powered on\n");
+		rockchip->lanes_map = GENMASK(MAX_LANE_NUM - 1, 0);
 	}
 
 	rockchip_pcie_write(rockchip, PCI_VENDOR_ID_ROCKCHIP,
@@ -387,6 +424,7 @@ static int rockchip_pcie_host_init_port(struct rockchip_pcie *rockchip)
 	rockchip_pcie_write(rockchip, status, PCIE_RC_CONFIG_CR + PCI_EXP_DEVCTL);
 
 	return 0;
+
 err_power_off_phy:
 	while (i--)
 		phy_power_off(rockchip->phys[i]);
