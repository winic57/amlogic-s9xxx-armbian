From 1111111111111111111111111111111111111111 Mon Sep 17 00:00:00 2001
From: henry <henry@example.com>
Date: Mon, 6 Jul 2026 18:25:00 +0800
Subject: [PATCH] pcie-rockchip-dma: add ioctl observation and soft failfast modes

Extend the 0010 runtime fail-fast controls with better observability and
safe intermediate modes before re-enabling real PCIe DMA for RKNN tests.

New debugfs state in pcie_trx:
  ioctl_count / last_cmd / last_ret
  soft_abort / soft_complete

New runtime control:
  /sys/kernel/debug/pcie/dma_failfast_mode

Modes are only used while dma_disabled=1:
  0: return -EIO, matching the 0010 fail-fast behaviour
  1: soft-abort with -ECANCELED, no hardware DMA start
  2: soft-complete with return 0, no hardware DMA start

All modes keep real DMA disabled. This allows RKNN/proxy call-sequence
A/B tests and timeout-value plumbing checks without immediately entering
the hardware DMA path that previously hard-hung the board.
---
 drivers/pci/controller/pcie-rockchip-dma.c | 92 +++++++++++++++++-----
 drivers/pci/controller/pcie-rockchip-dma.h |  7 ++
 2 files changed, 79 insertions(+), 20 deletions(-)

diff --git a/drivers/pci/controller/pcie-rockchip-dma.c b/drivers/pci/controller/pcie-rockchip-dma.c
--- a/drivers/pci/controller/pcie-rockchip-dma.c
+++ b/drivers/pci/controller/pcie-rockchip-dma.c
@@ -44,6 +44,9 @@
 #define PCIE_DMA_PARAM_SIZE		64
 #define PCIE_DMA_CHN0			0x0
 #define PCIE_DMA_DEFAULT_TIMEOUT_MS	5000
+#define PCIE_DMA_FAILFAST_ERROR		0
+#define PCIE_DMA_FAILFAST_SOFT_ABORT	1
+#define PCIE_DMA_FAILFAST_SOFT_COMPLETE	2
 
 static inline bool is_rc(struct dma_trx_obj *obj)
 {
@@ -175,6 +178,7 @@
 	while (!list_empty(&obj->tbl_list)) {
 		if (READ_ONCE(obj->dma_disabled)) {
 			obj->dma_abort_count++;
+			obj->dma_soft_abort_count++;
 			rk_pcie_dma_failfast_reset(obj);
 			dev_warn_ratelimited(obj->dev,
 					     "pcie dma disabled: dropping queued transfer\n");
@@ -231,6 +235,30 @@
 	       cmd == PCIE_DMA_WAIT_TRANSFER_COMPLETE;
 }
 
+static int rk_pcie_dma_disabled_ret(struct dma_trx_obj *obj, unsigned int cmd)
+{
+	u32 mode = READ_ONCE(obj->dma_failfast_mode);
+
+	if (mode > PCIE_DMA_FAILFAST_SOFT_COMPLETE)
+		mode = PCIE_DMA_FAILFAST_ERROR;
+
+	rk_pcie_dma_failfast_reset(obj);
+
+	switch (mode) {
+	case PCIE_DMA_FAILFAST_SOFT_COMPLETE:
+		if (cmd == PCIE_DMA_WAIT_TRANSFER_COMPLETE)
+			obj->loop_count = 0;
+		obj->dma_soft_complete_count++;
+		return 0;
+	case PCIE_DMA_FAILFAST_SOFT_ABORT:
+		obj->dma_soft_abort_count++;
+		return -ECANCELED;
+	case PCIE_DMA_FAILFAST_ERROR:
+	default:
+		return -EIO;
+	}
+}
+
 static void rk_pcie_dma_recover_timeout(struct dma_trx_obj *obj)
 {
 	if (obj->dma_free || !obj->dma_timeout_ms)
@@ -394,15 +422,24 @@
 	void __user *uarg = (void __user *)arg;
 	int ret;
 
-	if (copy_from_user(&msg, uarg, sizeof(msg)) != 0)
+	obj->ioctl_count++;
+	obj->last_ioctl_cmd = cmd;
+	obj->last_ioctl_ret = 0;
+
+	if (copy_from_user(&msg, uarg, sizeof(msg)) != 0) {
+		obj->last_ioctl_ret = -EFAULT;
 		return -EFAULT;
+	}
 
 	if (READ_ONCE(obj->dma_disabled) && rk_pcie_dma_cmd_needs_hw(cmd)) {
-		obj->dma_abort_count++;
-		rk_pcie_dma_failfast_reset(obj);
+		ret = rk_pcie_dma_disabled_ret(obj, cmd);
+		if (ret)
+			obj->dma_abort_count++;
+		obj->last_ioctl_ret = ret;
 		dev_warn_ratelimited(dev,
-				     "pcie dma disabled: fail-fast ioctl 0x%x\n", cmd);
-		return -EIO;
+				     "pcie dma disabled: mode=%u ioctl=0x%x ret=%d\n",
+				     READ_ONCE(obj->dma_failfast_mode), cmd, ret);
+		return ret;
 	}
 
 	switch (cmd) {
@@ -417,8 +454,10 @@
 		if (is_rc(obj))
 			addr += PCIE_DMA_WR_BUF_SIZE;
 		dma_sync_single_for_cpu(dev, addr, PCIE_DMA_RD_BUF_SIZE, DMA_FROM_DEVICE);
-		if (copy_to_user(uarg, &out, sizeof(out)))
+		if (copy_to_user(uarg, &out, sizeof(out))) {
+			obj->last_ioctl_ret = -EFAULT;
 			return -EFAULT;
+		}
 		break;
 	case PCIE_DMA_SET_LOCAL_READ_BUFFER_INDEX:
 		test_and_clear_bit(msg.in.idx, &obj->local_read_available);
@@ -426,8 +465,10 @@
 	case PCIE_DMA_GET_LOCAL_REMOTE_WRITE_BUFFER_INDEX:
 		out.out.lwa = obj->local_write_available;
 		out.out.rwa = obj->remote_write_available;
-		if (copy_to_user(uarg, &out, sizeof(out)))
+		if (copy_to_user(uarg, &out, sizeof(out))) {
+			obj->last_ioctl_ret = -EFAULT;
 			return -EFAULT;
+		}
 		break;
 	case PCIE_DMA_SYNC_BUFFER_FOR_CPU:
 		addr = obj->mem_start + msg.in.idx * PCIE_DMA_BUF_SIZE;
@@ -447,8 +488,10 @@
 		reinit_completion(&obj->done);
 		ret = wait_for_completion_interruptible_timeout(&obj->done,
 				msecs_to_jiffies(timeout_ms));
-		if (ret < 0)
+		if (ret < 0) {
+			obj->last_ioctl_ret = ret;
 			return ret;
+		}
 		if (!ret) {
 			obj->dma_timeout_count++;
 			dev_warn_ratelimited(dev,
@@ -456,6 +499,7 @@
 					     obj->loop_count, obj->loop_count_threshold,
 					     obj->last_dma_status, list_empty(&obj->tbl_list),
 					     obj->dma_free);
+			obj->last_ioctl_ret = -ETIMEDOUT;
 			return -ETIMEDOUT;
 		}
 		obj->loop_count = 0;
@@ -466,6 +510,7 @@
 		break;
 	default:
 		dev_dbg(dev, "unsupported ioctl 0x%x\n", cmd);
+		obj->last_ioctl_ret = -EINVAL;
 		return -EINVAL;
 	}
 
@@ -476,6 +521,7 @@
 		queue_work(obj->dma_trx_wq, &obj->dma_trx_work);
 	}
 
+	obj->last_ioctl_ret = 0;
 	return 0;
 }
 
@@ -631,10 +677,14 @@
 	seq_printf(s, "list : (%s), dma chn : (%s)\n",
 		   list_empty_now ? "empty" : "not empty",
 		   dma_obj->dma_free ? "free" : "busy");
-	seq_printf(s, "last_status = 0x%x, dma_disabled = %d, timeout_ms = %u, timeouts = %lu, aborts = %lu\n",
+	seq_printf(s, "last_status = 0x%x, dma_disabled = %d, failfast_mode = %u, timeout_ms = %u, timeouts = %lu, aborts = %lu\n",
 		   dma_obj->last_dma_status, dma_obj->dma_disabled,
-		   dma_obj->dma_timeout_ms, dma_obj->dma_timeout_count,
-		   dma_obj->dma_abort_count);
+		   dma_obj->dma_failfast_mode, dma_obj->dma_timeout_ms,
+		   dma_obj->dma_timeout_count, dma_obj->dma_abort_count);
+	seq_printf(s, "ioctl_count = %lu, last_cmd = 0x%x, last_ret = %d, soft_abort = %lu, soft_complete = %lu\n",
+		   dma_obj->ioctl_count, dma_obj->last_ioctl_cmd,
+		   dma_obj->last_ioctl_ret, dma_obj->dma_soft_abort_count,
+		   dma_obj->dma_soft_complete_count);
 	seq_printf(s, "irq_counts: udma = %lu, subsys = %lu, client = %lu\n",
 		   dma_obj->udma_irq_count, dma_obj->subsys_irq_count,
 		   dma_obj->client_irq_count);
@@ -719,11 +769,16 @@
 	mutex_init(&obj->count_mutex);
 	obj->dma_free = true;
 	obj->dma_timeout_ms = PCIE_DMA_DEFAULT_TIMEOUT_MS;
+	obj->dma_failfast_mode = PCIE_DMA_FAILFAST_ERROR;
 	obj->dma_disabled = of_property_read_bool(dev->of_node,
 						  "rockchip,pcie-dma-disabled");
 
 	of_property_read_u32(dev->of_node, "rockchip,dma-timeout-ms",
 			     &obj->dma_timeout_ms);
+	of_property_read_u32(dev->of_node, "rockchip,dma-failfast-mode",
+			     &obj->dma_failfast_mode);
+	if (obj->dma_failfast_mode > PCIE_DMA_FAILFAST_SOFT_COMPLETE)
+		obj->dma_failfast_mode = PCIE_DMA_FAILFAST_ERROR;
 
 	hrtimer_setup(&obj->scan_timer, rk_pcie_scan_timer, CLOCK_MONOTONIC, HRTIMER_MODE_REL);
 	hrtimer_start(&obj->scan_timer, ms_to_ktime(500), HRTIMER_MODE_REL);
@@ -750,10 +805,12 @@
 			    &obj->dma_disabled);
 	debugfs_create_u32("dma_timeout_ms", 0600, obj->pcie_root,
 			   &obj->dma_timeout_ms);
+	debugfs_create_u32("dma_failfast_mode", 0600, obj->pcie_root,
+			   &obj->dma_failfast_mode);
 #endif
 
-	dev_info(dev, "registered misc device pcie-dev (dma_disabled=%d timeout_ms=%u)\n",
-		 obj->dma_disabled, obj->dma_timeout_ms);
+	dev_info(dev, "registered misc device pcie-dev (dma_disabled=%d failfast_mode=%u timeout_ms=%u)\n",
+		 obj->dma_disabled, obj->dma_failfast_mode, obj->dma_timeout_ms);
 	return obj;
 
 err_misc:
diff --git a/drivers/pci/controller/pcie-rockchip-dma.h b/drivers/pci/controller/pcie-rockchip-dma.h
--- a/drivers/pci/controller/pcie-rockchip-dma.h
+++ b/drivers/pci/controller/pcie-rockchip-dma.h
@@ -71,9 +71,15 @@
 	u32				last_subsys_core_status;
 	u32				last_client_irq_status;
 	bool				dma_disabled;
+	u32				dma_failfast_mode;
 	u32				dma_timeout_ms;
 	unsigned long			dma_timeout_count;
 	unsigned long			dma_abort_count;
+	unsigned long			dma_soft_abort_count;
+	unsigned long			dma_soft_complete_count;
+	unsigned long			ioctl_count;
+	u32				last_ioctl_cmd;
+	int				last_ioctl_ret;
 	unsigned long			udma_irq_count;
 	unsigned long			subsys_irq_count;
 	unsigned long			client_irq_count;
-- 
2.43.0
