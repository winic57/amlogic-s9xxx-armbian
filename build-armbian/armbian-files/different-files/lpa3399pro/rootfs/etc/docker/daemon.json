{
  "data-root": "/mnt/sdcard/docker",
  "storage-driver": "overlay2",
  "iptables": true,
  "ip6tables": true,
  "ipv6": true,
  "fixed-cidr-v6": "fd00:dead:beef::/64",
  "experimental": true,
  "ip-masq": true,
  "ip-forward": true,
  "userland-proxy": true,
  "log-driver": "json-file",
  "log-opts": {
    "max-size": "5m",
    "max-file": "3"
  },
  "live-restore": true
}
